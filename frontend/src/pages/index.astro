---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Inicio">
  <div class="hero">
    <h1>Catálogo de Artículos Impresos en 3D</h1>
    <p class="muted">
      Explora nuestro catálogo de figuras, piezas y accesorios impresos en 3D. Inicia
      sesión para ver el catálogo completo o regístrate como cliente.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/catalogo">Ver catálogo</a>
      <a class="btn" href="/login">Iniciar sesión</a>
      <a class="btn" href="/registro">Registrarse</a>
    </div>
  </div>
</BaseLayout>
